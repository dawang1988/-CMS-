APP_DEBUG = false

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai
DEFAULT_TENANT_ID = 88888888
# 应用密钥（用于加密，生产环境请修改为随机字符串）
APP_KEY = your_random_secret_key_here_change_in_production
# 订单超时时间（分钟）
ORDER_TIMEOUT = 15
# 数据加密密钥（用于敏感数据加密）
ENCRYPT_KEY = your_encrypt_key_change_in_production

[ALERT]
# 告警Webhook地址（企业微信、钉钉等）
ALERT_WEBHOOK = 
# 告警手机号（短信通知）
ALERT_PHONE = 
# 告警邮箱（邮件通知）
ALERT_EMAIL = 

[SECURITY]
# 开发环境是否在短信发送失败时返回验证码（生产环境必须为 false）
SMS_DEBUG_RETURN_CODE = false

[CACHE]
DRIVER = file
# 生产环境建议使用 Redis
# DRIVER = redis

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = smart_store
USERNAME = root
PASSWORD = your_password_here
HOSTPORT = 3306
CHARSET = utf8mb4
DEBUG = false
PREFIX = ss_

[LANG]
default_lang = zh-cn

[WECHAT]
APP_ID = your_wechat_appid
APP_SECRET = your_wechat_appsecret

[REDIS]
HOST = 127.0.0.1
PORT = 6379
PASSWORD = 
SELECT = 0
TIMEOUT = 0
EXPIRE = 0
PERSISTENT = false
PREFIX = smart_store:

[CORS]
# 允许的跨域来源，多个用逗号分隔
# 生产环境必须设置具体域名，禁止使用 *
# 示例：ALLOWED_ORIGINS = https://yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS = *

[MQTT]
# EMQX Broker 地址
BROKER_HOST = 127.0.0.1
BROKER_PORT = 1883
# EMQX REST API（Dashboard HTTP API）
API_HOST = http://127.0.0.1:18083
API_KEY = your_emqx_api_key
API_SECRET = your_emqx_api_secret
# Topic 前缀
TOPIC_PREFIX = device/
# 默认 QoS
QOS = 1
# WebHook 回调密钥
WEBHOOK_SECRET = change_me_in_production

[LOG]
# 日志级别：debug, info, notice, warning, error
LEVEL = info
# 单个日志文件最大大小（MB）
MAX_SIZE = 50

[RATE_LIMIT]
# 是否启用限流
ENABLED = true
# 默认每分钟请求次数
DEFAULT_LIMIT = 60
